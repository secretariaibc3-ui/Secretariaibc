rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "q2qRJ6sgAEevGST5Cc3xJ03ks2H2" ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "secretariaibc3@gmail.com") ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "secretaria1@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isFullAdmin() {
      return isSignedIn() && (
        request.auth.uid == "q2qRJ6sgAEevGST5Cc3xJ03ks2H2" ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "secretariaibc3@gmail.com") ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "secretaria1@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isFullAdmin == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidMember(data) {
      return data.keys().hasAll(['name', 'function', 'isActive']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.function is string && data.function.size() > 0 && data.function.size() <= 200 &&
             data.isActive is bool &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 800000)) &&
             (!('birthDate' in data) || data.birthDate is string) &&
             (!('startDate' in data) || data.startDate is string) &&
             (!('gender' in data) || data.gender in ['Homem', 'Mulher']) &&
             (!('isAbsent' in data) || data.isAbsent is bool) &&
             (!('ministryIds' in data) || data.ministryIds is list) &&
             (!('ministries' in data) || data.ministries is list) &&
             (!('relationships' in data) || data.relationships is list) &&
             (!('exitDate' in data) || data.exitDate is string) &&
             (!('exitReason' in data) || data.exitReason is string) &&
             (!('celular' in data) || (data.celular is string && data.celular.size() <= 50)) &&
             (!('cep' in data) || (data.cep is string && data.cep.size() <= 20)) &&
             (!('logradouro' in data) || (data.logradouro is string && data.logradouro.size() <= 300)) &&
             (!('numero' in data) || (data.numero is string && data.numero.size() <= 50)) &&
             (!('complemento' in data) || (data.complemento is string && data.complemento.size() <= 205)) &&
             (!('bairro' in data) || (data.bairro is string && data.bairro.size() <= 200)) &&
             (!('cidade' in data) || (data.cidade is string && data.cidade.size() <= 200)) &&
             (!('estado' in data) || (data.estado is string && data.estado.size() <= 100)) &&
             (!('pais' in data) || (data.pais is string && data.pais.size() <= 100)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['admin', 'user'] &&
             (!('status' in data) || data.status in ['pending', 'approved', 'blocked']) &&
             (!('isFullAdmin' in data) || data.isFullAdmin is bool) &&
             (!('linkedMemberId' in data) || data.linkedMemberId is string || data.linkedMemberId == null) &&
             (!('requestAt' in data) || data.requestAt is timestamp || data.requestAt == null) &&
             (!('approvedAt' in data) || data.approvedAt is timestamp || data.approvedAt == null) &&
             (!('rejectedAt' in data) || data.rejectedAt is timestamp || data.rejectedAt == null) &&
             (!('handledByEmail' in data) || data.handledByEmail is string) &&
             (!('handledByUid' in data) || data.handledByUid is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidMinistry(data) {
      return data.keys().hasAll(['name', 'color']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.color is string && data.color.matches("^#[0-9a-fA-F]{6}$") &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 800000)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidAta(data) {
      return data.keys().hasAll(['number', 'date', 'content']) &&
             data.number is string && data.number.size() > 0 && data.number.size() <= 50 &&
             data.date is string &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 100000 &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 800000));
    }

    function isValidPresenca(data) {
      return data.keys().hasAll(['ataNumber', 'date']) &&
             data.ataNumber is string && data.ataNumber.size() > 0 &&
             data.date is string;
    }

    function isValidSettings(data) {
      return (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 800000)) &&
             (!('appName' in data) || (data.appName is string && data.appName.size() <= 100)) &&
             (!('churchCnpj' in data) || (data.churchCnpj is string && data.churchCnpj.size() <= 20));
    }

    function isValidMemberPhoto(data) {
      return data.keys().hasAll(['url', 'fileName', 'uploadedBy', 'createdAt']) &&
             data.url is string && data.url.size() <= 800000 &&
             data.fileName is string && data.fileName.size() <= 255 &&
             data.uploadedBy is string && data.uploadedBy == request.auth.token.email;
    }

    function isValidMemberFunction(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidRelationshipType(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidMinistryRole(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidAgeClassification(data) {
      return data.keys().hasAll(['name', 'minAge', 'maxAge']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.minAge is number && 
             data.maxAge is number &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'participants', 'content', 'status', 'createdAt']) &&
             data.senderId is string &&
             data.receiverId is string &&
             data.participants is list && data.participants.size() == 2 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 10000 &&
             data.status in ['sent', 'delivered', 'read'] &&
             data.createdAt is timestamp &&
             (!('senderName' in data) || data.senderName is string) &&
             (!('senderPhotoUrl' in data) || data.senderPhotoUrl is string) &&
             (!('receiverName' in data) || data.receiverName is string) &&
             (!('receiverPhotoUrl' in data) || data.receiverPhotoUrl is string) &&
             (!('readAt' in data) || data.readAt is timestamp || data.readAt == null);
    }

    // ===============================================================
    // Rules Matching
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /members/{memberId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isEmailVerified() && isValidMember(incoming());
      allow update: if isEmailVerified() && isValidMember(incoming());
      allow delete: if isFullAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
      allow list: if isAdmin();
      allow create: if isEmailVerified() && (
        isAdmin() || 
        (request.auth.uid == userId && incoming().role == 'user')
      ) && isValidUser(incoming());
      allow update: if isEmailVerified() && (
        isAdmin() || 
        (request.auth.uid == userId && incoming().status == 'pending' && incoming().role == existing().role && incoming().email == existing().email)
      ) && isValidUser(incoming());
      allow delete: if isFullAdmin();
    }

    match /ministries/{ministryId} {
      allow get, list: if isSignedIn();
      allow create, update: if isEmailVerified() && isValidMinistry(incoming());
      allow delete: if isFullAdmin();
    }

    match /atas/{ataId} {
      allow get, list: if isSignedIn();
      allow create, update: if isEmailVerified() && isValidAta(incoming());
      allow delete: if isAdmin();
    }

    match /presencas/{presencaId} {
      allow get, list: if isSignedIn();
      allow create, update: if isEmailVerified() && isValidPresenca(incoming());
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isFullAdmin() && isValidSettings(incoming());
    }

    match /memberPhotos/{photoId} {
      allow get, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidMemberPhoto(incoming());
      allow delete: if isEmailVerified() && (isAdmin() || existing().uploadedBy == request.auth.token.email);
    }

    match /memberFunctions/{functionId} {
      allow get, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidMemberFunction(incoming());
      allow update: if isFullAdmin() && isValidMemberFunction(incoming());
      allow delete: if isFullAdmin();
    }

    match /relationshipTypes/{typeId} {
      allow get, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidRelationshipType(incoming());
      allow update: if isFullAdmin() && isValidRelationshipType(incoming());
      allow delete: if isFullAdmin();
    }

    match /ministryRoles/{roleId} {
      allow get, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidMinistryRole(incoming());
      allow update: if isFullAdmin() && isValidMinistryRole(incoming());
      allow delete: if isFullAdmin();
    }

    match /messages/{messageId} {
      allow get: if isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow list: if isSignedIn() && (request.auth.uid in existing().participants || request.query.limit <= 100); 
      // Note: for list queries, the query must include a where clause on participants array containing request.auth.uid
      allow create: if isEmailVerified() && incoming().senderId == request.auth.uid && isValidMessage(incoming());
      allow update: if isEmailVerified() && (
        (existing().receiverId == request.auth.uid && incoming().status == 'read') ||
        (existing().receiverId == request.auth.uid && incoming().status == 'delivered')
      ) && isValidMessage(incoming());
      allow delete: if isFullAdmin();
    }

    match /ageClassifications/{classId} {
      allow get, list: if isSignedIn();
      allow create: if isEmailVerified();
      allow update: if isFullAdmin();
      allow delete: if isFullAdmin();
    }
  }
}
